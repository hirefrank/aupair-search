{
  "name": "aupair-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "preinstall": "node scripts/require-bun.mjs",
    "start": "node scripts/require-bun.mjs && bun src/index.ts",
    "crawl": "node scripts/require-bun.mjs && bun src/index.ts",
    "check:apia": "node scripts/require-bun.mjs && bun src/checkApiaSession.ts",
    "sync:secrets": "node scripts/require-bun.mjs && bash scripts/sync-culturecare-secrets.sh",
    "trigger:search": "node scripts/require-bun.mjs && bash scripts/trigger-search.sh",
    "worker:dev": "node scripts/require-bun.mjs && wrangler dev --remote",
    "worker:deploy": "node scripts/require-bun.mjs && wrangler deploy",
    "typecheck": "node scripts/require-bun.mjs && tsc --noEmit",
    "test": "node scripts/require-bun.mjs && bun test"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "hono": "^4.9.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^24.3.3",
    "typescript": "^5.9.2",
    "wrangler": "^4.41.0"
  }
}
