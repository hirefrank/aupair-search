# Worker runtime
ENABLE_CULTURECARE=true
MAX_PAGES=200

# Match filtering
MATCH_SCORE_THRESHOLD=60
MATCH_MIN_AGE=22
MATCH_REQUIRE_FEMALE=true
MATCH_MIN_ENGLISH_LEVEL=6
MATCH_ARRIVAL_EARLIEST=2026-06-01
MATCH_ARRIVAL_LATEST=2026-07-31
MATCH_CHILD_AGES=3,5
MATCH_REQUIRED_PETS=dogs
MATCH_ALLOWED_DRIVING_FREQUENCIES=daily,weekly
MATCH_MIN_DRIVING_YEARS=1
MATCH_REQUIRE_SWIMMING_SUPERVISION=true
MATCH_REQUIRE_LIVED_AWAY_FROM_HOME=true
SLACK_NOTIFY_MAX=25
MATCH_NOTIFIED_TTL_DAYS=30
SLACK_SKIP_KV_WRITES=true

# Notifications + manual trigger
SLACK_WEBHOOK_URL=
SLACK_ENABLE_DETAILS_MODAL=false
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Legacy fallback for action auth if signing secret is not set.
SLACK_ACTION_TOKEN=
CULTURECARE_REAUTH_URL=https://hostfamily.culturalcare.com
AUTH_ALERT_TTL_HOURS=12
MANUAL_TRIGGER_TOKEN=

# Culture Care auth (set at least one; refresh token is recommended)
CULTURECARE_REFRESH_TOKEN=
# CULTURECARE_BEARER=
# Browser extraction (used by sync script when bearer is missing)
# CULTURECARE_TOKEN_COMMAND=bun ./scripts/extract-culturecare-token-from-browser.mjs
# CULTURECARE_BROWSER=auto
# CULTURECARE_BROWSER_PROFILE_DIR=

# Culture Care search request body
CULTURECARE_SEARCH_BODY_JSON={}

# Optional Culture Care API overrides
CULTURECARE_COGNITO_REGION=us-east-1
CULTURECARE_COGNITO_CLIENT_ID=3jsqobi851prmu958rn4b0t26e
CULTURECARE_API_BASE=https://4bzk4o198j.execute-api.us-east-1.amazonaws.com/prod/v2/matching/search/au-pairs
CULTURECARE_PAGE_SIZE=50
CULTURECARE_RANDOM_SEED=43774025
CULTURECARE_RESULTS_PATH=data.auPairs
CULTURECARE_NEXT_TOKEN_PATH=data.nextToken
CULTURECARE_SKIP_ON_AUTH_ERROR=false

# Culture Care GraphQL (for bookmark/favorite feature)
CULTURECARE_HOST_FAMILY_ID=
# CULTURECARE_GRAPHQL_ENDPOINT=https://jn6xymv2sfgljcnnjzffb7jaum.appsync-api.us-east-1.amazonaws.com/graphql

# Optional scoring preferences JSON
# PREFERENCES_JSON={"preferredCountries":["Germany"],"requiredLanguages":["english"]}
